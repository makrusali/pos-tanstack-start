generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id           String        @id @default(uuid())
  name         String        @db.VarChar(255)
  email        String        @unique @db.VarChar(255)
  password     String        @db.VarChar(255)
  avatar_url   String?       @db.VarChar(255)
  role_id      String
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt
  role         Role          @relation(fields: [role_id], references: [id])
  transactions Transaction[]

  @@index([role_id], map: "users_role_id_fkey")
  @@map("users")
}

model Role {
  id               String              @id @default(uuid())
  name             String              @db.VarChar(255)
  created_at       DateTime            @default(now())
  updated_at       DateTime            @updatedAt
  role_permissions RoleHasPermission[]
  users            User[]

  @@map("roles")
}

model Permission {
  id               String              @id @default(uuid())
  module           String              @db.VarChar(255)
  action           String              @db.VarChar(255)
  created_at       DateTime            @default(now())
  updated_at       DateTime            @updatedAt
  role_permissions RoleHasPermission[]

  @@map("permissions")
}

model RoleHasPermission {
  role_id       String
  permission_id String
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt
  permission    Permission @relation(fields: [permission_id], references: [id])
  role          Role       @relation(fields: [role_id], references: [id])

  @@id([role_id, permission_id])
  @@index([permission_id], map: "role_has_permissions_permission_id_fkey")
  @@map("role_has_permissions")
}

model Unit {
  id          String       @id @default(uuid())
  name        String       @db.VarChar(255)
  type        UnitType
  status      Status
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
  productSkus ProductSku[]

  @@map("units")
}

model Category {
  id                String            @id @default(uuid())
  name              String            @db.VarChar(255)
  description       String?
  status            Status
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  productCategories ProductCategory[]

  @@map("categories")
}

model Product {
  id                String            @id @default(uuid())
  name              String            @db.VarChar(255)
  description       String?
  type              ProductType
  is_variant        Boolean           @default(false)
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  productCategories ProductCategory[]
  productSkus       ProductSku[]

  @@map("products")
}

model ProductCategory {
  category_id String
  product_id  String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  category    Category @relation(fields: [category_id], references: [id])
  product     Product  @relation(fields: [product_id], references: [id])

  @@id([category_id, product_id])
  @@index([product_id], map: "product_categories_product_id_fkey")
  @@map("product_categories")
}

model ProductSku {
  id               String                @id @default(uuid())
  code             String                @unique @db.VarChar(12)
  product_id       String
  name             String?               @db.VarChar(255)
  price            Int
  buy_price        Int
  stock_quantity   Decimal               @db.Decimal(10, 4)
  status           Status
  unit_id          String
  created_at       DateTime              @default(now())
  updated_at       DateTime              @updatedAt
  images           ProductSkuImage[]
  product          Product               @relation(fields: [product_id], references: [id])
  unit             Unit                  @relation(fields: [unit_id], references: [id])
  promotionItems   PromotionItem[]
  purchaseItems    PurchaseStockItem[]
  adjustmentItems  StockAdjustmentItem[]
  stockProductSkus StockProductSku[]
  transactionItems TransactionItem[]
  stockBatches     StockBatches[]

  @@index([product_id], map: "product_skus_product_id_fkey")
  @@index([unit_id], map: "product_skus_unit_id_fkey")
  @@map("product_skus")
}

model ProductSkuImage {
  id             String     @id @default(uuid())
  product_sku_id String
  path           String     @db.VarChar(255)
  created_at     DateTime   @default(now())
  updated_at     DateTime   @updatedAt
  productSku     ProductSku @relation(fields: [product_sku_id], references: [id])

  @@index([product_sku_id], map: "product_sku_images_product_sku_id_fkey")
  @@map("product_sku_images")
}

model StockLocation {
  id               String            @id @default(uuid())
  name             String            @unique @db.VarChar(255)
  note             String?
  status           Status
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt
  stockProductSkus StockProductSku[]
  stockBatches     StockBatches[]

  @@map("stock_locations")
}

model StockProductSku {
  id                String          @id @default(uuid())
  product_sku_id    String
  stock_location_id String
  is_primary        Boolean
  quantity          Decimal         @db.Decimal(10, 4)
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt
  stockMovements    StockMovement[]
  productSku        ProductSku      @relation(fields: [product_sku_id], references: [id])
  stockLocation     StockLocation   @relation(fields: [stock_location_id], references: [id])
  stockBatches      StockBatches[]

  @@index([product_sku_id], map: "stock_product_skus_product_sku_id_fkey")
  @@index([stock_location_id], map: "stock_product_skus_stock_location_id_fkey")
  @@map("stock_product_skus")
}

model StockBatches {
  id                   String @id @default(uuid())
  product_sku_id       String
  stock_product_sku_id String

  quantity           Decimal  @db.Decimal(10, 4)
  remaining_quantity Decimal  @db.Decimal(10, 4)
  buy_price          Int
  date               DateTime

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  source_reference String
  source_id        String

  productSku       ProductSku        @relation(fields: [product_sku_id], references: [id])
  stockProductSku  StockProductSku   @relation(fields: [stock_product_sku_id], references: [id])
  stockMovements   StockMovement[]
  stockBatchUsages StockBatchUsage[]

  stockLocation     StockLocation?    @relation(fields: [stock_location_id], references: [id])
  stock_location_id String?           @map("stock_location_id")
  transactionItems  TransactionItem[]

  @@index([product_sku_id], map: "stock_batches_product_sku_id_fkey")
  @@index([stock_product_sku_id], map: "stock_batches_stock_product_skus_id_fkey")
  @@map("stock_batches")
}

model StockBatchUsage {
  id               String @id @default(uuid())
  stock_batches_id String

  prev_quantity    Decimal @db.Decimal(10, 4)
  quantity         Decimal @db.Decimal(10, 4)
  current_quantity Decimal @db.Decimal(10, 4)

  stockBatch StockBatches @relation(fields: [stock_batches_id], references: [id])

  @@map("stock_batch_usages")
}

model Promotion {
  id                    String                 @id @default(uuid())
  name                  String                 @db.VarChar(255)
  description           String?
  start_date            DateTime
  end_date              DateTime
  start_time            DateTime
  end_time              DateTime
  created_at            DateTime               @default(now())
  updated_at            DateTime               @updatedAt
  promotionItems        PromotionItem[]
  promotionTransactions PromotionTransaction[]
  transactions          Transaction[]

  @@map("promotions")
}

model PromotionTransaction {
  id             String        @id @default(uuid())
  promotion_id   String
  name           String        @db.VarChar(255)
  discount_value Float
  discount_type  DiscountType
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt
  promotion      Promotion     @relation(fields: [promotion_id], references: [id])
  transactions   Transaction[]

  @@index([promotion_id], map: "promotion_transactions_promotion_id_fkey")
  @@map("promotion_transactions")
}

model PromotionItem {
  id             String       @id @default(uuid())
  promotion_id   String
  product_sku_id String
  discount_value Float
  discount_type  DiscountType

  min_qty             Decimal?
  is_multiple_allowed Boolean?

  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt
  productSku       ProductSku        @relation(fields: [product_sku_id], references: [id])
  promotion        Promotion         @relation(fields: [promotion_id], references: [id])
  transactionItems TransactionItem[]

  @@index([product_sku_id], map: "promotion_items_product_sku_id_fkey")
  @@index([promotion_id], map: "promotion_items_promotion_id_fkey")
  @@map("promotion_items")
}

model Customer {
  id           String        @id @default(uuid())
  name         String        @db.VarChar(255)
  address      String?
  email        String?
  phone        String?
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt
  transactions Transaction[]

  @@map("customers")
}

model Supplier {
  id         String   @id @default(uuid())
  name       String   @db.VarChar(255)
  address    String?
  email      String?
  phone      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("suppliers")
}

model Transaction {
  id                          String                   @id @default(uuid())
  code                        String
  status                      TransactionStatus
  payment_status              TransactionPaymentStatus
  remaining_payment           Int                      @default(0)
  customer_id                 String?
  note                        String?
  promotion_id                String?
  transaction_discount_id     String?
  transaction_discount_type   DiscountType?
  transaction_discount_value  Float?
  transaction_discount_amount Int
  items_discount_amount       Int
  discount_total              Int

  price_before_discount_total Int
  price_total                 Int

  other_cost_total Int                   @map("other_cost_total")
  grand_total      Int
  transaction_date DateTime              @default(now())
  anotherFees      OtherCost[]
  payments         Payment[]
  transactionItems TransactionItem[]
  customer         Customer?             @relation(fields: [customer_id], references: [id])
  promotion        Promotion?            @relation(fields: [promotion_id], references: [id])
  discount         PromotionTransaction? @relation(fields: [transaction_discount_id], references: [id])

  maker    User   @relation(fields: [maker_id], references: [id])
  maker_id String

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([customer_id], map: "transactions_customer_id_fkey")
  @@index([promotion_id], map: "transactions_promotion_id_fkey")
  @@index([transaction_discount_id], map: "transactions_transaction_discount_id_fkey")
  @@map("transactions")
}

model PaymentMethod {
  id          String    @id @default(uuid())
  name        String    @db.VarChar(255)
  description String?
  status      Status
  image_path  String?   @db.VarChar(255)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  payments    Payment[]

  @@map("payment_methods")
}

model Payment {
  id                String        @id @default(uuid())
  transaction_id    String
  payment_method_id String
  status            PaymentStatus
  total             Int
  change            Int
  balance           Int
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt
  paymentMethod     PaymentMethod @relation(fields: [payment_method_id], references: [id])
  transaction       Transaction   @relation(fields: [transaction_id], references: [id])

  @@index([payment_method_id], map: "payments_payment_method_id_fkey")
  @@index([transaction_id], map: "payments_transaction_id_fkey")
  @@map("payments")
}

model TransactionItem {
  id             String  @id @default(uuid())
  note           String?
  transaction_id String
  product_sku_id String
  quantity       Decimal @db.Decimal(10, 4)

  stock_batches_id String?
  buy_price        Int
  price            Int
  discounted_price Int
  subtotal         Int
  discount_id      String?
  discount_value   Float?
  discount_type    DiscountType?
  discount_amount  Int
  discount_total   Int

  discount_min_qty             Decimal?
  discount_is_multiple_allowed Boolean?

  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt
  discount    PromotionItem? @relation(fields: [discount_id], references: [id])
  productSku  ProductSku     @relation(fields: [product_sku_id], references: [id])
  transaction Transaction    @relation(fields: [transaction_id], references: [id])
  stockBatch  StockBatches?  @relation(fields: [stock_batches_id], references: [id])

  @@index([discount_id], map: "transaction_items_discount_id_fkey")
  @@index([product_sku_id], map: "transaction_items_product_sku_id_fkey")
  @@index([transaction_id], map: "transaction_items_transaction_id_fkey")
  @@map("transaction_items")
}

model OtherCost {
  id             String      @id @default(uuid())
  transaction_id String
  note           String?
  price          Int
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt
  transaction    Transaction @relation(fields: [transaction_id], references: [id])

  @@index([transaction_id], map: "other_costs_transaction_id_fkey")
  @@map("other_costs")
}

model StockMovement {
  id                   String          @id @default(uuid())
  reference_type       String          @db.VarChar(255)
  reference_id         String          @db.VarChar(255)
  stock_product_sku_id String
  prev_quantity        Decimal         @db.Decimal(10, 4)
  quantity             Decimal         @db.Decimal(10, 4)
  current_quantity     Decimal         @db.Decimal(10, 4)
  type                 MovementType
  transaction_date     DateTime        @default(now())
  note                 String?
  created_at           DateTime        @default(now())
  updated_at           DateTime        @updatedAt
  stockProductSku      StockProductSku @relation(fields: [stock_product_sku_id], references: [id])
  stockBatches         StockBatches?   @relation(fields: [stock_batches_id], references: [id])
  stock_batches_id     String?

  @@index([stock_product_sku_id], map: "stock_movements_stock_product_sku_id_fkey")
  @@map("stock_movements")
}

model PurchaseStock {
  id               String              @id @default(uuid())
  status           PurchaseStatus
  supplier_name    String              @db.VarChar(255)
  note             String?
  transaction_date DateTime            @default(now())
  total            Int
  created_at       DateTime            @default(now())
  updated_at       DateTime            @updatedAt
  items            PurchaseStockItem[]

  @@map("purchase_stocks")
}

model PurchaseStockItem {
  id                String             @id @default(uuid())
  status            PurchaseItemStatus
  purchase_stock_id String
  product_sku_id    String
  buy_price         Int
  quantity          Decimal            @db.Decimal(10, 4)
  total             Int
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt
  productSku        ProductSku         @relation(fields: [product_sku_id], references: [id])
  purchaseStock     PurchaseStock      @relation(fields: [purchase_stock_id], references: [id])

  @@index([product_sku_id], map: "purchase_stock_items_product_sku_id_fkey")
  @@index([purchase_stock_id], map: "purchase_stock_items_purchase_stock_id_fkey")
  @@map("purchase_stock_items")
}

model StockAdjustment {
  id               String                @id @default(uuid())
  status           AdjustmentStatus
  note             String?
  transaction_date DateTime              @default(now())
  created_at       DateTime              @default(now())
  updated_at       DateTime              @updatedAt
  items            StockAdjustmentItem[]

  @@map("stock_adjustments")
}

model StockAdjustmentItem {
  id                 String          @id @default(uuid())
  stock_adjusment_id String
  product_sku_id     String
  quantity           Float
  created_at         DateTime        @default(now())
  updated_at         DateTime        @updatedAt
  productSku         ProductSku      @relation(fields: [product_sku_id], references: [id])
  stockAdjustment    StockAdjustment @relation(fields: [stock_adjusment_id], references: [id])

  @@index([product_sku_id], map: "stock_adjustment_items_product_sku_id_fkey")
  @@index([stock_adjusment_id], map: "stock_adjustment_items_stock_adjusment_id_fkey")
  @@map("stock_adjustment_items")
}

model Expense {
  id               String        @id @default(uuid())
  status           ExpenseStatus
  note             String?
  transaction_date DateTime      @default(now())
  total            Int
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt
  items            ExpenseItem[]

  @@map("expenses")
}

model ExpenseItem {
  id         String   @id @default(uuid())
  expense_id String
  name       String   @db.VarChar(255)
  total      Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  expense    Expense  @relation(fields: [expense_id], references: [id])

  @@index([expense_id], map: "expense_items_expense_id_fkey")
  @@map("expense_items")
}

model Report {
  id         String   @id @default(uuid())
  start_date DateTime
  end_date   DateTime
  omset      Int
  expenses   Int
  sales      Int
  profit     Int
  tax_type   TaxType
  tax_value  Float
  tax_total  Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("reports")
}

model Setting {
  id                    String      @id @default(uuid())
  store_name            String      @db.VarChar(255)
  store_phone           String      @db.VarChar(255)
  store_email           String      @db.VarChar(255)
  store_description     String?
  store_address         String?
  stock_guard           GuardStatus
  receipent_thanks_text String?
  created_at            DateTime    @default(now())
  updated_at            DateTime    @updatedAt

  @@map("settings")
}

enum UnitType {
  integer
  decimal
}

enum Status {
  active
  inactive
}

enum ProductType {
  item
  service
}

enum DiscountType {
  percent
  fixed
}

enum TransactionStatus {
  draft
  done
  cancelled
}

enum PaymentStatus {
  paid
  unpaid
}

enum TransactionPaymentStatus {
  paid
  unpaid
  partial
}

enum MovementType {
  in
  out
}

enum PurchaseStatus {
  draft
  pending
  done
  cancelled
}

enum PurchaseItemStatus {
  pending
  received
  refunded
}

enum AdjustmentStatus {
  draft
  done
  cancelled
}

enum ExpenseStatus {
  draft
  done
  cancelled
}

enum TaxType {
  fixed
  percent
}

enum GuardStatus {
  active
  inactive
}
