generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id         String   @id @default(uuid())
  name       String   @db.VarChar(255)
  email      String   @unique @db.VarChar(255)
  password   String   @db.VarChar(255)
  avatar_url String?  @db.VarChar(255)
  role_id    String
  role       Role     @relation(fields: [role_id], references: [id])
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("users")
}

model Role {
  id               String              @id @default(uuid())
  name             String              @db.VarChar(255)
  users            User[]
  role_permissions RoleHasPermission[]
  created_at       DateTime            @default(now())
  updated_at       DateTime            @updatedAt

  @@map("roles")
}

model Permission {
  id               String              @id @default(uuid())
  module           String              @db.VarChar(255)
  action           String              @db.VarChar(255)
  role_permissions RoleHasPermission[]
  created_at       DateTime            @default(now())
  updated_at       DateTime            @updatedAt

  @@map("permissions")
}

model RoleHasPermission {
  role_id       String
  permission_id String
  role          Role       @relation(fields: [role_id], references: [id])
  permission    Permission @relation(fields: [permission_id], references: [id])
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  @@id([role_id, permission_id])
  @@map("role_has_permissions")
}

model Unit {
  id          String       @id @default(uuid())
  name        String       @db.VarChar(255)
  type        UnitType
  status      Status
  productSkus ProductSku[]
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt

  @@map("units")
}

enum UnitType {
  integer
  decimal
}

enum Status {
  active
  inactive
}

model Category {
  id                String            @id @default(uuid())
  name              String            @db.VarChar(255)
  description       String?
  status            Status
  productCategories ProductCategory[]
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt

  @@map("categories")
}

model Product {
  id                String            @id @default(uuid())
  name              String            @db.VarChar(255)
  description       String?
  type              ProductType
  is_variant        Boolean           @default(false)
  productCategories ProductCategory[]
  productSkus       ProductSku[]
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt

  @@map("products")
}

enum ProductType {
  item
  service
}

model ProductCategory {
  category_id String
  product_id  String
  category    Category @relation(fields: [category_id], references: [id])
  product     Product  @relation(fields: [product_id], references: [id])
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@id([category_id, product_id])
  @@map("product_categories")
}

model ProductSku {
  id               String                @id @default(uuid())
  code             String                @unique @db.VarChar(12)
  product_id       String
  name             String?               @db.VarChar(255)
  price            Int                   @db.Int
  buy_price        Int
  stock_quantity   Float
  status           Status
  unit_id          String
  product          Product               @relation(fields: [product_id], references: [id])
  unit             Unit                  @relation(fields: [unit_id], references: [id])
  images           ProductSkuImage[]
  stockProductSkus StockProductSku[]
  promotionItems   PromotionItem[]
  transactionItems TransactionItem[]
  purchaseItems    PurchaseStockItem[]
  adjustmentItems  StockAdjustmentItem[]
  created_at       DateTime              @default(now())
  updated_at       DateTime              @updatedAt

  @@map("product_skus")
}

model ProductSkuImage {
  id             String     @id @default(uuid())
  product_sku_id String
  path           String     @db.VarChar(255)
  productSku     ProductSku @relation(fields: [product_sku_id], references: [id])
  created_at     DateTime   @default(now())
  updated_at     DateTime   @updatedAt

  @@map("product_sku_images")
}

model StockLocation {
  id               String            @id @default(uuid())
  name             String            @unique @db.VarChar(255)
  note             String?
  status           Status
  stockProductSkus StockProductSku[]
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt

  @@map("stock_locations")
}

model StockProductSku {
  id                String          @id @default(uuid())
  product_sku_id    String
  stock_location_id String
  is_primary        Boolean
  quantity          Float
  productSku        ProductSku      @relation(fields: [product_sku_id], references: [id])
  stockLocation     StockLocation   @relation(fields: [stock_location_id], references: [id])
  stockMovements    StockMovement[]
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt

  @@map("stock_product_skus")
}

model Promotion {
  id                    String                 @id @default(uuid())
  name                  String                 @db.VarChar(255)
  description           String?
  start_date            DateTime
  end_date              DateTime
  start_time            DateTime
  end_time              DateTime
  promotionTransactions PromotionTransaction[]
  promotionItems        PromotionItem[]
  transactions          Transaction[]
  created_at            DateTime               @default(now())
  updated_at            DateTime               @updatedAt

  @@map("promotions")
}

model PromotionTransaction {
  id             String        @id @default(uuid())
  promotion_id   String
  name           String        @db.VarChar(255)
  discount_value Float
  discount_type  DiscountType
  promotion      Promotion     @relation(fields: [promotion_id], references: [id])
  transactions   Transaction[]
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt

  @@map("promotion_transactions")
}

model PromotionItem {
  id                  String            @id @default(uuid())
  promotion_id        String
  product_sku_id      String
  discount_value      Float
  discount_type       DiscountType
  min_qty             Float?
  is_multiple_allowed Boolean?
  promotion           Promotion         @relation(fields: [promotion_id], references: [id])
  productSku          ProductSku        @relation(fields: [product_sku_id], references: [id])
  transactionItems    TransactionItem[]
  created_at          DateTime          @default(now())
  updated_at          DateTime          @updatedAt

  @@map("promotion_items")
}

enum DiscountType {
  percent
  fixed
}

model Customer {
  id           String        @id @default(uuid())
  name         String        @db.VarChar(255)
  address      String?
  contact      String?
  transactions Transaction[]
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt

  @@map("customers")
}

model Transaction {
  id               String                @id @default(uuid())
  status           TransactionStatus
  customer_id      String?
  promotion_id     String?
  note             String?
  discount_value   Float?
  discount_type    DiscountType?
  discount_id      String?
  discount_total   Int
  price_total      Int                   @db.Int
  another_total    Int                   @db.Int
  grand_total      Int                   @db.Int
  transaction_date DateTime              @default(now())
  customer         Customer?             @relation(fields: [customer_id], references: [id])
  promotion        Promotion?            @relation(fields: [promotion_id], references: [id])
  discount         PromotionTransaction? @relation(fields: [discount_id], references: [id])
  payments         Payment[]
  transactionItems TransactionItem[]
  anotherFees      AnotherFee[]
  created_at       DateTime              @default(now())
  updated_at       DateTime              @updatedAt

  @@map("transactions")
}

enum TransactionStatus {
  draft
  done
  cancelled
}

model PaymentMethod {
  id          String    @id @default(uuid())
  name        String    @db.VarChar(255)
  description String?
  status      Status
  image_path  String?   @db.VarChar(255)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  payments    Payment[]

  @@map("payment_methods")
}

model Payment {
  id                String        @id @default(uuid())
  transaction_id    String
  payment_method_id String
  paymentMethod     PaymentMethod @relation(fields: [payment_method_id], references: [id])
  status            PaymentStatus
  total             Int           @db.Int
  change            Int           @db.Int
  balance           Int           @db.Int
  transaction       Transaction   @relation(fields: [transaction_id], references: [id])
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt

  @@map("payments")
}

enum PaymentStatus {
  paid
  unpaid
}

model TransactionItem {
  id             String         @id @default(uuid())
  note           String?
  transaction_id String
  product_sku_id String
  quantity       Float
  price          Int
  subtotal       Int
  discount_value Float?
  discount_type  DiscountType?
  discount_id    String?
  discount_total Int
  total          Int
  transaction    Transaction    @relation(fields: [transaction_id], references: [id])
  productSku     ProductSku     @relation(fields: [product_sku_id], references: [id])
  discount       PromotionItem? @relation(fields: [discount_id], references: [id])
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt

  @@map("transaction_items")
}

model AnotherFee {
  id             String      @id @default(uuid())
  transaction_id String
  note           String?
  price          Int
  transaction    Transaction @relation(fields: [transaction_id], references: [id])
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt

  @@map("another_fees")
}

model StockMovement {
  id                   String          @id @default(uuid())
  reference_type       String          @db.VarChar(255)
  reference_id         String          @db.VarChar(255)
  stock_product_sku_id String
  prev_quantity        Float
  quantity             Float
  current_quantity     Float
  type                 MovementType
  transaction_date     DateTime        @default(now())
  note                 String?
  stockProductSku      StockProductSku @relation(fields: [stock_product_sku_id], references: [id])
  created_at           DateTime        @default(now())
  updated_at           DateTime        @updatedAt

  @@map("stock_movements")
}

enum MovementType {
  in
  out
}

model PurchaseStock {
  id               String              @id @default(uuid())
  status           PurchaseStatus
  supplier_name    String              @db.VarChar(255)
  note             String?
  transaction_date DateTime            @default(now())
  total            Int
  items            PurchaseStockItem[]
  created_at       DateTime            @default(now())
  updated_at       DateTime            @updatedAt

  @@map("purchase_stocks")
}

enum PurchaseStatus {
  draft
  pending
  done
  cancelled
}

model PurchaseStockItem {
  id                String             @id @default(uuid())
  status            PurchaseItemStatus
  purchase_stock_id String
  product_sku_id    String
  quantity          Float
  total             Int
  purchaseStock     PurchaseStock      @relation(fields: [purchase_stock_id], references: [id])
  productSku        ProductSku         @relation(fields: [product_sku_id], references: [id])
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt

  @@map("purchase_stock_items")
}

enum PurchaseItemStatus {
  pending
  received
  refunded
}

model StockAdjustment {
  id               String                @id @default(uuid())
  status           AdjustmentStatus
  note             String?
  transaction_date DateTime              @default(now())
  items            StockAdjustmentItem[]
  created_at       DateTime              @default(now())
  updated_at       DateTime              @updatedAt

  @@map("stock_adjustments")
}

enum AdjustmentStatus {
  draft
  done
  cancelled
}

model StockAdjustmentItem {
  id                 String          @id @default(uuid())
  stock_adjusment_id String
  product_sku_id     String
  quantity           Float
  stockAdjustment    StockAdjustment @relation(fields: [stock_adjusment_id], references: [id])
  productSku         ProductSku      @relation(fields: [product_sku_id], references: [id])
  created_at         DateTime        @default(now())
  updated_at         DateTime        @updatedAt

  @@map("stock_adjustment_items")
}

model Expense {
  id               String        @id @default(uuid())
  status           ExpenseStatus
  note             String?
  transaction_date DateTime      @default(now())
  total            Int
  items            ExpenseItem[]
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  @@map("expenses")
}

enum ExpenseStatus {
  draft
  done
  cancelled
}

model ExpenseItem {
  id         String   @id @default(uuid())
  expense_id String
  name       String   @db.VarChar(255)
  total      Int
  expense    Expense  @relation(fields: [expense_id], references: [id])
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("expense_items")
}

model Report {
  id         String   @id @default(uuid())
  start_date DateTime
  end_date   DateTime
  omset      Int
  expenses   Int
  sales      Int
  profit     Int
  tax_type   TaxType
  tax_value  Float
  tax_total  Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("reports")
}

enum TaxType {
  fixed
  percent
}

model Setting {
  id                    String      @id @default(uuid())
  store_name            String      @db.VarChar(255)
  store_phone           String      @db.VarChar(255)
  store_email           String      @db.VarChar(255)
  store_description     String?
  store_address         String?
  stock_guard           GuardStatus
  receipent_thanks_text String?
  created_at            DateTime    @default(now())
  updated_at            DateTime    @updatedAt

  @@map("settings")
}

enum GuardStatus {
  active
  inactive
}
